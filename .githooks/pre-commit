#!/bin/sh

export UID=$(id -u)
export GID=$(id -g)

trap 'cleanup' INT

cleanup() {
  printf "\n⚠️ \033[33m%s\033[0m\n" "Aborted pre-commit hook"
  kill 0
  exit 1
}

run_command () {
  COMMAND_NAME=$1
  COMMAND_RUN=$2
  (
    OUTPUT=$(eval "$COMMAND_RUN" 2>&1)
    status_code=$?

    if [ $status_code -ne 0 ]; then
      printf "\r\033[K❌ %s \033[31m%s\033[0m\n" "$COMMAND_NAME" "failed" >&2
      echo "$OUTPUT" > "/tmp/${COMMAND_NAME}_pre-commit"
      exit 1
    else
      printf "\r\033[K✅ %s \033[32m%s\033[0m\n" "$COMMAND_NAME" "passed" >&2
    fi
  ) &
}

report_failures () {
  PATTERN=$1
  for OUTPUT_FILE in $PATTERN; do
    if [ ! -f "$OUTPUT_FILE" ]; then
      continue
    fi

    HOOK_EXIT_CODE=1
    printf "\n----------------\n❌ %s\n\n" "$(basename "$OUTPUT_FILE" '_pre-commit')"
    cat "$OUTPUT_FILE"
    rm "$OUTPUT_FILE"
  done
}

printf "🐚 \033[33m%s\033[0m\n\n" "Executing pre-commit hook..."

# PHP
printf "======= %s =======\033[33m%s\033[0m\n" "PHP" >&2

# Staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=AMR | grep -E '\.php$|\.php-cs-fixer(\.dist)?\.php|composer\.lock|phpunit\.xml|phpstan(-baseline)?\.neon' | tr '\n' ' ')

HOOK_EXIT_CODE=0
if [ "$STAGED_FILES" ]; then
  # PHP-CS-Fixer; run on changed files or on whole project if .php-cs-fixer.dist.php/composer.lock has changed
  EXTRA_ARGS=''
  IFS='
  '
  if ! echo "${STAGED_FILES}" | grep -qE '\.php-cs-fixer(\.dist)?\.php|composer\.lock'; then
    EXTRA_ARGS=$(printf -- '--path-mode=intersection %s' "${STAGED_FILES}")
  fi

  docker compose up --no-start php >/dev/null 2>&1 || true

  run_command "PHP-CS-Fixer" "docker compose run -T --rm --no-deps php vendor/bin/php-cs-fixer fix --dry-run -v --diff --config=.php-cs-fixer.dist.php --show-progress=none $EXTRA_ARGS"
  run_command "PHPStan" "docker compose run -T --rm --no-deps php vendor/bin/phpstan --memory-limit=1G --error-format=table"
  run_command "PHPMD" "docker compose run -T --rm --no-deps php vendor/bin/phpmd src/ text phpmd.xml"
  run_command "PHPUnit" "docker compose run -T --rm --no-deps php vendor/bin/phpunit"

  wait
  report_failures "/tmp/PHP-CS-Fixer_pre-commit"
  report_failures "/tmp/PHPStan_pre-commit"
  report_failures "/tmp/PHPMD_pre-commit"
  report_failures "/tmp/PHPUnit_pre-commit"
else
    printf "ℹ️ No staged PHP files\n"
    HOOK_EXIT_CODE=0
fi

# GitHub Actions workflows
printf "\n======= %s =======\033[33m%s\033[0m\n" "GitHub Actions" >&2

WORKFLOW_STAGED_FILES=$(git diff --cached --name-only --diff-filter=AMR \
  | grep -E '^\.github/workflows/.+\.ya?ml$' \
  | xargs)
if [ "$WORKFLOW_STAGED_FILES" ]; then
  run_command "Actionlint" "docker run --rm -v \"$(pwd):/repo\" --workdir /repo rhysd/actionlint:1.7.12 -color $WORKFLOW_STAGED_FILES"
  run_command "Zizmor" "docker run --rm -v \"$(pwd):/repo\" --workdir /repo ghcr.io/zizmorcore/zizmor:1.25.2 --color=always $WORKFLOW_STAGED_FILES"
  run_command "Pinact" "docker run --rm -v \"$(pwd):/repo\" ghcr.io/toshy/docker-pinact:4.1.0 run --diff $WORKFLOW_STAGED_FILES"

  wait
  report_failures "/tmp/Actionlint_pre-commit"
  report_failures "/tmp/Zizmor_pre-commit"
  report_failures "/tmp/Pinact_pre-commit"
else
    printf "ℹ️ No staged GitHub Actions workflow files\n"
fi

printf "\n"
exit $HOOK_EXIT_CODE
